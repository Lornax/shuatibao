# 刷题宝 backend 环境变量
# 复制为 .env 后填写。不要把 .env 提交到 git。

PORT=3001

# PostgreSQL 连接串
DATABASE_URL=postgres://<your-pg-user>@localhost:5432/shuatibao

# 后端 Bearer token，需与 frontend/.env.local 的 VITE_API_TOKEN 一致
# 生成: openssl rand -hex 16
API_TOKEN=

# 初始用户 UUID。跑 `npm run seed` 后会输出，粘贴回来即可。
SEED_USER_ID=

# JWT 签名密钥，至少 16 字符
# 生成: openssl rand -hex 32
JWT_SECRET=

# 阿里云百炼 API key，作为通用 AI fallback
DASHSCOPE_API_KEY=

# 可选：百炼 coding plan 备用 key
DASHSCOPE_CODING_API_KEY=
DASHSCOPE_CODING_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# 可选：硅基流动 embedding
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 可选：小米 MiMo chat/text/vision
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# 可选：腾讯云 COS，用于 PDF 原文件归档和教材文件存储。四项都填写才会启用。
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=

# 可选：生产环境 HTTP Basic Auth。/api/* 和 /health 不走这层。
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
