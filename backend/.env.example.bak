# 刷题宝 backend 环境变量
# 复制为 .env 后填写

# === 必填 ===

PORT=3001

# PostgreSQL 连接串. 本地推荐 Postgres.app: https://postgresapp.com
# 创建 db: createdb shuatibao
DATABASE_URL=postgres://lornax@localhost:5432/shuatibao

# 后端 Bearer token (开发期单用户兜底, 跟 frontend/.env.local 的 VITE_API_TOKEN 一致)
# 生成: openssl rand -hex 16
API_TOKEN=

# 初始用户 UUID. 跑 `npm run seed` 后会输出, 粘贴回来即可
SEED_USER_ID=

# JWT 签名密钥, 至少 16 字符
# 生成: openssl rand -hex 32
JWT_SECRET=

# 阿里云百炼平台 API key, 驱动所有 AI 能力:
#   - qwen-vl-max: 拍照识题
#   - qwen-max: PDF 文本结构化 / AI 出题 / AI 解题
#   - deepseek-v3: 题目页问 AI / 陪学对话
#   - text-embedding-v3: 查重 embedding
# 申请: https://bailian.console.aliyun.com (新用户 100 万 token 免费额度)
DASHSCOPE_API_KEY=

# === 可选 ===

# 腾讯云 COS (PDF 原文件归档 + 教材文件存储)
# 4 个都设才激活, 不配则跳过 (功能可用但 PDF 上传后无法再下载)
# 申请: https://console.cloud.tencent.com/cos
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=

# 生产环境 HTTP Basic Auth (防止 SPA bundle 被爬虫拿到 token)
# /api/* 和 /health 跳过这层
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# AI fallback: 主 DASHSCOPE_API_KEY 配额耗尽时自动切到这个备用 key
# 走 https://coding.dashscope.aliyuncs.com/v1 端点, 模型映射在 src/ai/client.ts
# 不配则原 key 用尽时直接报错
DASHSCOPE_CODING_API_KEY=
